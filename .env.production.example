# ============================================================================
# PRODUCTION ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and update with your actual values
# DO NOT commit .env file with real credentials to GitHub
# ============================================================================

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>
MONGO_URI=mongodb+srv://alok_db:kwGSgzutsLVsLgqK@cluster0.9nogei1.mongodb.net/?appName=Cluster0

# ==============================================================================
# AUTHENTICATION & SECURITY
# ==============================================================================
# JWT secret key for token generation (use a strong random string)
JWT_SECRET=acfb83cbc248dbf1ce4258af7b8581089b4b3ad26af4f7bc95d205a4962b9f5f

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================
# Port your Express server runs on
PORT=5000

# Node environment (production, development, staging)
NODE_ENV=production

# Client URL for CORS (your Vercel frontend URL)
CLIENT_URL=https://portfolio-alok-kr.vercel.app

# Comma-separated list of allowed CORS origins
# Include localhost for development, production URLs for production
CORS_ORIGINS=https://portfolio-alok-kr.vercel.app,http://localhost:5173,http://127.0.0.1:5173

# Allow Vercel preview deployments (set to 'true' if using preview URLs)
ALLOW_VERCEL_PREVIEW=false

# ==============================================================================
# CLOUDINARY CONFIGURATION (Image & File Uploads)
# ==============================================================================
# Get these from https://cloudinary.com/console
# 1. Sign up for free account
# 2. Go to Dashboard
# 3. Copy Cloud Name, API Key, API Secret

# Your Cloudinary cloud name
CLOUDINARY_CLOUD_NAME=dbiwmqvpo

# Cloudinary API key
CLOUDINARY_API_KEY=785593557264721

# Cloudinary API secret (KEEP THIS SECRET - never commit to GitHub)
CLOUDINARY_API_SECRET=4551juE5bCPG_IhgQ_6P3qBcESQ

# ==============================================================================
# EMAIL CONFIGURATION (Contact Form)
# ==============================================================================
# Gmail or any email service that supports app passwords
# For Gmail: https://support.google.com/accounts/answer/185833

# Email address for sending form submissions
EMAIL_USER=test.work5681@gmail.com

# App-specific password (NOT your regular password)
EMAIL_PASS=klwfizoedmtzlpyf

# ==============================================================================
# RENDER-SPECIFIC CONFIGURATION
# ==============================================================================
# Set by Render automatically, used for keep-alive pings to prevent spin-down
# Format: https://yourapp.onrender.com
# RENDER_URL=https://portfolio-backend-0l58.onrender.com

# ==============================================================================
# FRONTEND ENVIRONMENT VARIABLES
