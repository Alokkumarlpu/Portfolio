# Render Environment Variables - Production Configuration
# Copy and set these in Render Dashboard: Service Settings → Environment

# Node environment
NODE_ENV=production
PORT=5000

# MongoDB Atlas
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT Secret - Use a long random string (min 32 characters)
JWT_SECRET=your_long_random_jwt_secret_minimum_32_characters_required

# Cloudinary Image Hosting
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS & Frontend URL
# Set to your Vercel frontend domain
CLIENT_URL=https://your-portfolio.vercel.app
CORS_ORIGINS=https://your-portfolio.vercel.app

# GMAIL SMTP FOR EMAIL - CRITICAL CONFIGURATION
# ============================================
# EMAIL_USER: Your full Gmail address (e.g., yourname@gmail.com)
# EMAIL_PASS: Gmail App Password (16 characters, NOT your regular Gmail password)
# 
# HOW TO GET GMAIL APP PASSWORD:
# 1. Go to myaccount.google.com
# 2. Click Security (left sidebar)
# 3. Enable 2-Step Verification if not already enabled
# 4. Find "App passwords" section (only appears with 2FA enabled)
# 5. Select: Mail, Windows Computer (or your device)
# 6. Click Create
# 7. Copy the 16-character password shown (format: abcd abcd abcd abcd)
# 8. Paste below WITHOUT spaces: abcdabcdabcdabcd
#
# TROUBLESHOOTING:
# - If you see "535 5.7.8 Username and Password not accepted":
#   → You're using regular Gmail password, not App Password
#   → Generate the 16-char App Password at step 5 above
#
# - If you see "534 5.7.14 Please log in via your web browser":
#   → 2-Factor Authentication not enabled
#   → Enable 2FA in Google Account settings
#
# - If you see "EAUTH" or "ESOCKET" errors:
#   → Wrong credentials
#   → Network/firewall issue on Render
#   → Contact Render support if connection blocked
#
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=xxxxxxxxxxxxxxxx

# Optional: Render service URL (for keep-alive checks)
RENDER_URL=https://your-service-name.onrender.com

