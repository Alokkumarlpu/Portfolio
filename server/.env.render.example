# Render Environment Variables - Production Configuration
# Copy and set these in Render Dashboard: Service Settings → Environment

# Node environment
NODE_ENV=production
PORT=5000

# MongoDB Atlas
# Format: mongodb+srv://username:password@cluster-name.mongodb.net/database-name?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/portfolio?retryWrites=true&w=majority

# JWT Secret - Use a long random string (min 32 characters)
JWT_SECRET=your_long_random_jwt_secret_minimum_32_characters_required

# Cloudinary Image Hosting
# Sign up at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# CORS & Frontend URL
# Set to your Vercel frontend domain
CLIENT_URL=https://your-portfolio.vercel.app
CORS_ORIGINS=https://your-portfolio.vercel.app

# RESEND EMAIL CONFIGURATION
# ==========================
# Get API key from: https://resend.com/api-keys
# For testing, EMAIL_FROM can be onboarding@resend.dev
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=Portfolio <onboarding@resend.dev>
EMAIL_USER=your-email@gmail.com

# Optional: Render service URL (for keep-alive checks)
RENDER_URL=https://your-service-name.onrender.com

